rules_version = '2';

/**
 * FIRESTORE SECURITY RULES
 *
 * Data Structure (matches src/firebase/sessions.ts):
 * - /sessions/{sessionId}: one uploaded audit-log file per session
 *   (fileName, uploadedAt, rowCount, logSnippet, storageRef).
 * - /sessions/{sessionId}/analyses/{analysisId}: forensic/replication AI
 *   results saved against that session.
 *
 * This app has no login UI, so there is no per-user ownership model for
 * sessions — every visitor is signed in anonymously (see
 * src/firebase/provider.tsx) purely so requests carry *some* authenticated
 * UID. Access below is shared across all authenticated (including
 * anonymous) users of this tool, not scoped per-owner.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    match /sessions/{sessionId} {
      allow get, list, create, update, delete: if isSignedIn();

      match /analyses/{analysisId} {
        allow get, list, create, update, delete: if isSignedIn();
      }
    }

    // Default deny for anything else.
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
